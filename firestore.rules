rules_version = '2';

// Data model:
//   /users/{uid}/meta/settings        -> sprint + goal config (1 doc)
//   /users/{uid}/checkins/{yyyy-mm-dd} -> one doc per day
//   /users/{uid}/weights/{yyyy-mm-dd}  -> one doc per weigh-in day
//   /users/{uid}/tokens/{tokenId}       -> registered FCM push tokens for this device/user
//
// Everything lives under the signed-in user's own uid. Nobody (including other
// authenticated users) can read or write another user's subtree.

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
